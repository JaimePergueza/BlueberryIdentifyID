# Copy this file to `.env` for local development. Never commit the real `.env`
# (it is already listed in .gitignore). Values below are local-dev defaults,
# not secrets — replace them with real credentials only in a properly
# secured deployment environment, never by editing this example file.

ENVIRONMENT=development

# SQLAlchemy connection string. Must point at PostgreSQL — SQLite is only
# used internally by this project's repository integration tests.
DATABASE_URL=postgresql+psycopg://blueberry:blueberry@localhost:5432/blueberry_microid

# Root directory for locally stored images. Relative paths are resolved
# against the repository root, not the process's current working directory.
STORAGE_ROOT=./storage
PETRI_IMAGE_DIR=petri_images
MICRO_IMAGE_DIR=micro_images

# Maximum accepted size, in megabytes, for a single Petri/micro image upload.
# Requests over this limit get a 413 response before the file ever reaches
# the image validator or storage.
MAX_UPLOAD_SIZE_MB=20

LOG_LEVEL=INFO
# 'json' for machine-parseable log lines, 'console' for human-readable local dev output.
LOG_FORMAT=console

# Celery/Redis local development defaults. These are not secrets.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
